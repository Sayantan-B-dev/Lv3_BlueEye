
# Database & Cache (MongoDB / Redis)
# WARNING: Create a dedicated DB user with Read/Write permissions only. Do not use Atlas Admin.
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<appName>"
MONGODB_DB_NAME=your_db_name
MONGODB_DB_COLLECTION_NAME=your_collection
# WARNING: Never log this URL or expose it to the client
REDIS_URL="rediss://default:<password>@<host>.upstash.io:6379"

# Authentication (NextAuth & Admin Credentials)
NEXTAUTH_URL=https://yourdomain.com
# Generate using: openssl rand -base64 32
NEXTAUTH_SECRET=<generate_with_openssl_rand_base64_32>

# WARNING: Storing admin credentials in env is high risk. Consider using DB-based role management.
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=your_admin_password_here

# File Uploads (ImageKit)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
# WARNING: Never prefix this with NEXT_PUBLIC_
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_endpoint
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_endpoint

# Email Service (Resend)
# WARNING: Never prefix this with NEXT_PUBLIC_
RESEND_API=your_resend_api_key
EMAIL_TO=your_email_to@example.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# WARNING: Never prefix this with NEXT_PUBLIC_
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Update to your production domain
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/callback/google

# Brand Identity & App URLs
NEXT_PUBLIC_BRAND_NAME="Your Brand Name"
NEXT_PUBLIC_BRAND_SHORT_NAME=YourBrandName
NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# Social Media Links
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/yourhandle
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/yourhandle
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/yourhandle
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@yourhandle
NEXT_PUBLIC_TWITTER_HANDLE=@yourhandle

# Contact Information
# WARNING: Information here is exposed to the client and can be scraped by bots.
NEXT_PUBLIC_CONTACT_EMAIL=public_contact@example.com
NEXT_PUBLIC_CONTACT_PHONE="+1 234 567 8900"
NEXT_PUBLIC_CONTACT_ADDRESS_1="123 Example Street, City, Country"
NEXT_PUBLIC_CONTACT_ADDRESS_2="456 Another Street, City, Country"

# WhatsApp Integration
# WARNING: Do not use for authentication/authorization
WHATSAPP_PHONE_NUMBER=12345678900

# SEO & Site Verification
GOOGLE_SITE_VERIFICATION="your_google_site_verification"
BING_SITE_VERIFICATION="your_bing_site_verification"

# Redis Cache Keys & Settings
REDIS_CACHE_KEY_PREFIX=your_app_prefix

# Home Page Data
HOME_DATA_REDIS_CACHE_KEY=your_app_prefix:home:data
HOME_DATA_CACHE_TTL_SECONDS=600
NEXT_PUBLIC_HOME_CLIENT_CACHE_KEY=your_app_prefix_home_data

# Auth Pending User
AUTH_PENDING_USER_CACHE_PREFIX=your_app_prefix:auth:pending-user
AUTH_PENDING_USER_TTL_SECONDS=600

# User Favorites
USER_FAVORITES_CACHE_PREFIX=your_app_prefix:user:favorites
USER_FAVORITES_IDS_CACHE_PREFIX=your_app_prefix:user:favorites-ids
USER_FAVORITES_CACHE_TTL_SECONDS=1800

# User Reviews & Marquee
REVIEWS_ALL_MARQUEE_CACHE_KEY=your_app_prefix:reviews:marquee
REVIEWS_ALL_MARQUEE_CACHE_TTL_SECONDS=300
USER_REVIEW_CACHE_PREFIX=your_app_prefix:user:review
REVIEWS_MINE_CACHE_TTL_SECONDS=300
